{
	"extends": "../../.eslintrc.json",
	"ignorePatterns": ["!**/*"],
	"overrides": [
		{
			"files": ["*.ts"],
			"rules": {
				"@angular-eslint/directive-selector": [],
				"@angular-eslint/component-selector": [
					"error",
					{
						"type": "element",
						"prefix": "ngx",
						"style": "kebab-case"
					}
				]
			}
		},
		{
			"files": ["*.html"],
			"rules": {}
		}
	]
}
